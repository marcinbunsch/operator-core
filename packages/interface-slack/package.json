{
  "name": "@operator/interface-slack",
  "version": "0.0.1",
  "description": "Slack interface for Operator agents",
  "keywords": [
    "agent",
    "effect",
    "operator",
    "slack"
  ],
  "license": "MIT",
  "author": "Marcin Bunsch",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "checks": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@slack/bolt": "^4.3.1",
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "@effect/vitest": "^0.27.0",
    "@types/node": "^22.15.3",
    "@typescript/native-preview": "7.0.0-dev.20260227.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
