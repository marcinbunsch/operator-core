{
  "name": "@operator/sdk",
  "version": "0.0.1",
  "description": "SDK for the Operator AI agent ecosystem",
  "keywords": [
    "agent",
    "ai",
    "effect",
    "operator"
  ],
  "license": "MIT",
  "author": "Marcin Bunsch",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./interfaces/slack": {
      "types": "./dist/interfaces/slack/index.d.ts",
      "import": "./dist/interfaces/slack/index.js"
    },
    "./interfaces/slack/testing": {
      "types": "./dist/interfaces/slack/testing.d.ts",
      "import": "./dist/interfaces/slack/testing.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "checks": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/ai": "^0.33.2",
    "@effect/ai-anthropic": "^0.23.0",
    "@effect/ai-openai": "^0.39.2",
    "@effect/platform": "^0.94.5",
    "cron-parser": "^4.9.0",
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "@effect/vitest": "^0.27.0",
    "@slack/bolt": "^4.3.1",
    "@typescript/native-preview": "7.0.0-dev.20260227.1",
    "@vitest/coverage-v8": "^3.2.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "@slack/bolt": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@slack/bolt": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.30.3"
}
