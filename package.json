{
  "name": "@operator/core",
  "version": "0.0.1",
  "description": "Framework foundation for the Operator AI agent ecosystem",
  "keywords": [
    "agent",
    "ai",
    "effect",
    "operator"
  ],
  "license": "MIT",
  "author": "Marcin Bunsch",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "checks": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260227.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
